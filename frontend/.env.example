# Optional — WalletConnect / mobile wallets via Reown.
# If set, add your app origin at https://cloud.reown.com (e.g. http://localhost:3000).
# If unset, only browser extension wallets (injected) are offered — no allowlist needed.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional — server-side Graph access used by the dashboard Home tab.
THEGRAPH_API_KEY=
THEGRAPH_SUBGRAPH_URL=

# Optional — explicit Sepolia RPC for server-side token metadata lookups.
SEPOLIA_RPC_URL=

# Optional — explicit Sepolia RPC for client-side wagmi/viem calls.
# Without this, wagmi uses the chain's default public RPC which may hit
# CORS errors and rate limits (429) from the browser.
NEXT_PUBLIC_SEPOLIA_RPC_URL=
